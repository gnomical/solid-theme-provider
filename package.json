{
  "name": "solid-theme-provider",
  "description": "Lightweight and customizable theme handler for Solid JS",
  "author": "Jacob Kofron",
  "license": "MIT",
  "version": "1.0.0",
  "homepage": "https://github.com/gnomical/solid-theme-provider#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gnomical/solid-theme-provider.git"
  },
  "keywords": [
    "solid",
    "solidjs",
    "ui",
    "themes",
    "dark-mode",
    "prefers-color-scheme"
  ],
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "dist/index.jsx",
  "module": "dist/index.jsx",
  "exports": {
    ".": "./dist/index.jsx"
  },
  "types": "types/index.d.ts",
  "files": [
    "dist",
    "types"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc",
    "prepublishOnly": "npm run build",
    "prettier": "npx prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.8.2",
    "solid-js": "^1.9.12",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vite": "^7.3.2",
    "vite-plugin-solid": "^2.11.12"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  }
}
