{
  "name": "solid-theme-provider",
  "description": "Lightweight and customizable theme handler for Solid JS",
  "author": "Jacob Kofron",
  "license": "MIT",
  "version": "1.1.0",
  "homepage": "https://stp.jacobkofron.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gnomical/solid-theme-provider.git"
  },
  "keywords": [
    "solid",
    "solidjs",
    "ui",
    "themes",
    "dark-mode",
    "prefers-color-scheme"
  ],
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "solid": "./dist/index.jsx",
      "default": "./dist/index.jsx"
    }
  },
  "types": "types/index.d.ts",
  "files": [
    "dist",
    "types",
    "AGENTS.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && tsc",
    "prepublishOnly": "npm run build",
    "prettier": "npx prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.2",
    "solid-js": "^1.9.12",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vite": "^7.3.2",
    "vite-plugin-lib-inject-css": "^2.2.2"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  }
}
