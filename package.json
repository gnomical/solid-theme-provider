{
  "name": "solid-theme-provider",
  "description": "Lightweight and customizable theme handler for Solid JS",
  "author": "Jacob Kofron",
  "license": "MIT",
  "version": "0.10.2",
  "homepage": "https://github.com/gnomical/solid-theme-provider#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gnomical/solid-theme-provider.git"
  },
  "keywords": [
    "solid",
    "solidjs",
    "ui",
    "themes",
    "dark-mode",
    "prefers-color-scheme"
  ],
  "type": "module",
  "main": "dist/index.jsx",
  "module": "dist/index.jsx",
  "types": "types/index.d.ts",
  "files": [
    "dist",
    "types"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c && tsc",
    "prepublishOnly": "npm run build",
    "prettier": "npx prettier --write ."
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "babel-preset-solid": "^1.9.12",
    "postcss": "^8.5.9",
    "prettier": "^3.8.1",
    "rollup": "^4.60.1",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.99.0",
    "solid-js": "^1.9.12",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  }
}
